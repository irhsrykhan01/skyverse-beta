# Bot identity
BOT_NAME=SkyVerse
PREFIX=.

# Comma-separated list of owner phone numbers (no +, no @s.whatsapp.net)
# Example: OWNER_NUMBERS=6281234567890,14155552671
OWNER_NUMBERS=

# Login method: set to true to use pairing code instead of QR
USE_PAIRING_CODE=false
# Phone number to use for pairing code login (no +). Leave empty to be prompted at startup.
PAIRING_NUMBER=

# Storage locations
SESSION_DIR=./session
DATABASE_PATH=./data/database.json

# Timezone used for timestamps (IANA format, e.g. Asia/Jakarta, America/New_York)
TIMEZONE=UTC

# Reconnect delay in milliseconds after an unexpected disconnect
RECONNECT_DELAY_MS=5000

# Baileys internal logger level: silent, fatal, error, warn, info, debug, trace
BAILEYS_LOG_LEVEL=silent

# Enable verbose bot debug logs
DEBUG=false

# Default cooldown (in seconds) applied to commands that don't set their own
DEFAULT_COOLDOWN_SECONDS=3
